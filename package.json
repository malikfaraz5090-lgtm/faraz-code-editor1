  "devDependencies": {
    "@capacitor/android": "^5.6.0",
    "@capacitor/cli": "^5.6.0",
    "@capacitor/core": "^5.6.0",
    "serve": "^14.2.1",
    "sharp": "^0.33.1"
  }
}